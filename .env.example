# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cloudcommerce"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Nepal Payment Gateways
KHALTI_SECRET_KEY=khalti_test_...
ESEWA_MERCHANT_CODE=ESEWA_TEST

# Sentry
SENTRY_DSN=

# CSRF Secret (generate with: openssl rand -hex 32)
CSRF_SECRET=

# Upload provider: local | s3
UPLOAD_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# Logging: debug | info | warn | error
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000
