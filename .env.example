# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cloudcommerce"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Nepal Payment Gateways
KHALTI_SECRET_KEY=khalti_test_...
ESEWA_MERCHANT_CODE=ESEWA_TEST

# Sentry
SENTRY_DSN=

# CSRF Secret (generate with: openssl rand -hex 32)
CSRF_SECRET=

# Storage Provider (auto-selects: R2 → S3 → Local)
# Local: no config needed — files stored in public/uploads/
# S3
S3_BUCKET=cloud-commerce
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=               # Optional: custom S3-compatible endpoint
S3_FORCE_PATH_STYLE=false   # Set true for MinIO, DigitalOcean Spaces
S3_PUBLIC_URL=              # Optional: custom CDN/public URL
# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=cloud-commerce
R2_PUBLIC_URL=              # Optional: custom domain

# Image Processing
IMAGE_MAX_SIZE_MB=10

# Logging: debug | info | warn | error
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000
